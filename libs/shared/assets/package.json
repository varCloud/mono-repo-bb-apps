{
  "name": "bb-app",
  "version": "0.0.1",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "ios:emulator": "npx cap sync && ionic capacitor run ios --livereload --external",
    "android:emulator": "npx cap sync && ionic capacitor run android --livereload --external",
    "celular": "npx cap sync && ionic cap run android --livereload --external",
    "moto": "npx cap sync && ionic cap run android --livereload --external --target=ZY22D585DS --host=192.168.1.27",
    "sync": "npx cap sync",
    "android": "ionic cap build android && node scripts/sync-android-files.js",
    "resources": "npm run resources:android && npm run resources:ios",
    "resources:android": "npx capacitor-assets generate --android",
    "resources:ios": "npx capacitor-assets generate --ios",
    "sync:ios": "ionic cap sync ios && node scripts/sync-ios-files.js",
    "sync:android": "ionic cap sync android && node scripts/sync-android-files.js"
  },
  "private": true,
  "dependencies": {
